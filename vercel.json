{
  "name": "transitflow-ai",
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "devCommand": "npm start",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/predict",
      "permanent": false
    }
  ]
}